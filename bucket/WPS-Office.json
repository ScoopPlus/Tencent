    "persist": "data",
    "pre_install": [
        "Expand-7zipArchive \"$dir\\`$EXEFILE\" -Switches '-t#'",
        "Remove-Item \"$dir\\*\" -Exclude '4.7z','2.7z' -Recurse",
        "Expand-7zipArchive \"$dir\\4.7z\" -ExtractDir 'office6' -Removal",
        "Expand-7zipArchive \"$dir\\2.7z\" -ExtractDir 'CONTROL\\office6' -Removal"
    ],
    "post_uninstall": "if ($purge -and (Test-Path \"$Env:APPDATA\\WPS Office\")) { Remove-Item -Recurse -Force \"$Env:APPDATA\\WPS Office\" }",
    "checkver": {
        "url": "https://luban.m.qq.com/api/public/software-manager/softwareProxy",
        "script": [
            "$Result = Invoke-RestMethod -Uri $url -Method Post -Body 'cmdid=3318&jprxReq%5Breq%5D%5Bsoft_id_list%5D%5B%5D=1215'",
            "@($Result.resp.soft_list.ver_name,$Result.resp.soft_list.download_https_url) | ConvertTo-Json -Compress | Write-Output"
        ],
        "regex": "\"([\\d\\.]+)\",\"https://sw.pcmgr.qq.com/(?<path>.+?)\""
    },
    "autoupdate": {
        "url": "https://sw.pcmgr.qq.com/$matchPath#/WPS-Office.7z"
