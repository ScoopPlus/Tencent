{
    "version": "5.17.10.11087",
    "description": "WinSCP是一款支持SSH(Secure SHell)的SCP(Secure CoPy)文件传输软件",
    "homepage": "https://pc.qq.com/detail/11/detail_2331.html",
    "license": "GPL-3.0-or-later",
    "url": "https://sw.pcmgr.qq.com/ee0ce661704ce8fe6104c4e202fce5c4/6a4953f5/spcmgr/download/WinSCP-5.17.10-Setup.exe",
    "hash": "16caaceb26e654d1ffebe159751bbd46840ad0eba4e0f5da2c4e105c3da44d1d",
    "innosetup": true,
    "shortcuts": [
        [
            "WinSCP.exe",
            "WinSCP"
        ]
    ],
    "pre_install": [
        "if (!(Test-Path \"$persist_dir\\winscp.ini\")) {",
        "    @(",
        "        '[Configuration\\Interface]'",
        "        \"RandomSeedFile=$persist_dir\\winscp.rnd\"",
        "    ) | Add-Content -Path \"$dir\\winscp.ini\" -Encoding ASCII -Force",
        "}"
    ],
    "persist": [
        "winscp.ini",
        "Translations"
    ],
    "checkver": {
        "url": "https://luban.m.qq.com/api/public/software-manager/softwareProxy",
        "script": [
            "$Result = Invoke-RestMethod -Uri $url -Method Post -Body 'cmdid=3318&jprxReq%5Breq%5D%5Bsoft_id_list%5D%5B%5D=2331'",
            "@($Result.resp.soft_list.ver_name,$Result.resp.soft_list.download_https_url) | ConvertTo-Json -Compress | Write-Output"
        ],
        "regex": "\"([\\d\\.]+)\",\"https://sw.pcmgr.qq.com/(?<path>.+?)\""
    },
    "autoupdate": {
        "url": "https://sw.pcmgr.qq.com/$matchPath"
    }
}
